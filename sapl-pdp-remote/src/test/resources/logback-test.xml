<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Forward container stdout (Slf4jLogConsumer on the test class logger). -->
    <logger name="io.sapl.pdp.remote.RemoteHttpDecisionPointServerIT" level="INFO"/>

    <!-- Code-under-test loggers: tests drive these into error/retry paths on
         purpose and assert on captured events via a ListAppender. Temporarily
         attached to the console (additivity=true, level kept at WARN so the
         ListAppender assertions are unchanged) so the actual fail-close error
         from logStreamError reaches CI while diagnosing the flaky IT. -->
    <logger name="io.sapl.pdp.remote.RemoteHttpReactivePolicyDecisionPoint" level="WARN"/>
    <logger name="io.sapl.pdp.remote.RemotePdpRetry" level="WARN"/>

    <!-- Late buffer-release noise on stream cancel during MockWebServer teardown. -->
    <logger name="reactor.netty.channel.FluxReceive" level="OFF"/>
    <logger name="io.netty.channel.DefaultChannelPipeline" level="OFF"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
