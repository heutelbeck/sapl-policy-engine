# Maintainer: Dominic Heutelbeck <dominic@heutelbeck.com>
#
# Install from the repository:
#   cd sapl-node/packaging/arch && makepkg -si
#
# Or from AUR (if published):
#   yay -S sapl

pkgname=sapl
pkgver=4.0.0_SNAPSHOT
pkgrel=1
pkgdesc='SAPL Node PDP server and policy management CLI'
arch=('x86_64' 'aarch64')
url='https://github.com/heutelbeck/sapl-policy-engine'
license=('Apache-2.0')
depends=('glibc')
install=sapl.install
backup=('etc/sapl/application.yml')

# Map makepkg arch names to release archive platform suffixes.
_platform_x86_64='linux-amd64'
_platform_aarch64='linux-arm64'

# Release version used in archive filenames (dots not underscores).
_relver="${pkgver//_/-}"

source_x86_64=("sapl-${pkgver}-x86_64.tar.gz::https://github.com/heutelbeck/sapl-policy-engine/releases/download/snapshot-node/sapl-${_relver}-${_platform_x86_64}.tar.gz")
source_aarch64=("sapl-${pkgver}-aarch64.tar.gz::https://github.com/heutelbeck/sapl-policy-engine/releases/download/snapshot-node/sapl-${_relver}-${_platform_aarch64}.tar.gz")

# Update after each release. Compute with: sha256sum sapl-*.tar.gz
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    install -Dm755 sapl "${pkgdir}/usr/bin/sapl"
    install -Dm644 "${srcdir}/../sapl.service" "${pkgdir}/usr/lib/systemd/system/sapl.service"
    install -Dm644 "${srcdir}/../default-config.yml" "${pkgdir}/etc/sapl/application.yml"
    install -dm750 "${pkgdir}/var/lib/sapl"
    install -Dm644 "${srcdir}/../README" "${pkgdir}/var/lib/sapl/README"
    install -Dm644 "${srcdir}/../example/pdp.json" "${pkgdir}/var/lib/sapl/example/pdp.json"
    install -Dm644 "${srcdir}/../example/deny-all.sapl" "${pkgdir}/var/lib/sapl/example/deny-all.sapl"
    for manpage in man/*.1; do install -Dm644 "$manpage" "${pkgdir}/usr/share/man/man1/$(basename "$manpage")"; done
}
