requirement "Environment Attribute Verification" {

    given
        - document "location-policy"
        - attribute "loc" <geo.location> emits { "country": "DE" }

    scenario "environment attribute called once"
        when "user" attempts "read" on "data"
        expect permit
        verify
            - attribute <geo.location> is called once;

}

requirement "Eager Mode Short-Circuits On A Pure FALSE Before The Stream" {

    given
        - documents "location-policy", "bypass-policy"
        - attribute "loc-bypass" <geo.location> emits { "country": "DE" }

    scenario "eager mode still short-circuits on the pure condition before subscribing the stream"
        when "user" attempts "bypass" on "data"
        expect permit
        verify
            - attribute <geo.location> is never called;

}

requirement "Environment Attribute Not Called Under Lazy Mode" {

    given
        - documents "location-policy", "bypass-policy"
        - low-latency-mode false
        - attribute "loc-bypass-lazy" <geo.location> emits { "country": "DE" }

    scenario "lazy coverage voter short-circuits before unused attribute"
        when "user" attempts "bypass" on "data"
        expect permit
        verify
            - attribute <geo.location> is never called;

}

requirement "Entity Attribute Verification" {

    given
        - document "role-policy"
        - attribute "role" any.<user.role> emits "admin"

    scenario "entity attribute called once"
        when { "id": "alice" } attempts "admin" on "system"
        expect permit
        verify
            - attribute any.<user.role> is called once;

}

requirement "Eager Mode Subscribes A Stream Dominated By An Earlier Stream" {

    given
        - documents "two-stream-policy", "bypass-policy"
        - attribute "first-eager" <first.attr> emits { "ok": true }
        - attribute "second-eager" <second.attr> emits { "ok": true }

    scenario "eager subscribes the dominated second stream up front"
        when "user" attempts "bypass" on "data"
        expect permit
        verify
            - attribute <second.attr> is called once;

}

requirement "Lazy Mode Short-Circuits Before A Stream Dominated By An Earlier Stream" {

    given
        - documents "two-stream-policy", "bypass-policy"
        - low-latency-mode false
        - attribute "first-lazy" <first.attr> emits { "ok": true }
        - attribute "second-lazy" <second.attr> emits { "ok": true }

    scenario "lazy stops at the dominating first stream and never subscribes the second"
        when "user" attempts "bypass" on "data"
        expect permit
        verify
            - attribute <second.attr> is never called;

}
