policy "filler-complex-0010"
permit
    action == "action-0010";
    resource == "resource-0010";
    "role-0010" in subject.roles;
    subject.department =~ "^department-0010.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0010 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0010 by " + subject.name
    }
