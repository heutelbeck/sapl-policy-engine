policy "filler-complex-0006"
permit
    action == "action-0006";
    resource == "resource-0006";
    "role-0006" in subject.roles;
    subject.department =~ "^department-0006.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0006 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0006 by " + subject.name
    }
