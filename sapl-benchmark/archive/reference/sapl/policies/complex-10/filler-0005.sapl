policy "filler-complex-0005"
permit
    action == "action-0005";
    resource == "resource-0005";
    "role-0005" in subject.roles;
    subject.department =~ "^department-0005.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0005 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0005 by " + subject.name
    }
