policy "filler-complex-0095"
permit
    action == "action-0095";
    resource == "resource-0095";
    "role-0095" in subject.roles;
    subject.department =~ "^department-0095.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0095 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0095 by " + subject.name
    }
