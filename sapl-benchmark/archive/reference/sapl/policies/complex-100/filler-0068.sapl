policy "filler-complex-0068"
permit
    action == "action-0068";
    resource == "resource-0068";
    "role-0068" in subject.roles;
    subject.department =~ "^department-0068.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0068 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0068 by " + subject.name
    }
