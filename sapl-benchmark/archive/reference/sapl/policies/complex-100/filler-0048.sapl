policy "filler-complex-0048"
permit
    action == "action-0048";
    resource == "resource-0048";
    "role-0048" in subject.roles;
    subject.department =~ "^department-0048.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0048 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0048 by " + subject.name
    }
