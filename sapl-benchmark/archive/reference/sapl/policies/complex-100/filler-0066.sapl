policy "filler-complex-0066"
permit
    action == "action-0066";
    resource == "resource-0066";
    "role-0066" in subject.roles;
    subject.department =~ "^department-0066.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0066 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0066 by " + subject.name
    }
