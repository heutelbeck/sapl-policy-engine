policy "filler-complex-0096"
permit
    action == "action-0096";
    resource == "resource-0096";
    "role-0096" in subject.roles;
    subject.department =~ "^department-0096.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0096 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0096 by " + subject.name
    }
