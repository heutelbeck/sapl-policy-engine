policy "filler-complex-0011"
permit
    action == "action-0011";
    resource == "resource-0011";
    "role-0011" in subject.roles;
    subject.department =~ "^department-0011.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0011 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0011 by " + subject.name
    }
