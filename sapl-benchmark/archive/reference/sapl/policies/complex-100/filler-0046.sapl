policy "filler-complex-0046"
permit
    action == "action-0046";
    resource == "resource-0046";
    "role-0046" in subject.roles;
    subject.department =~ "^department-0046.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0046 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0046 by " + subject.name
    }
