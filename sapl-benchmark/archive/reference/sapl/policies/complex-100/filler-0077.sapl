policy "filler-complex-0077"
permit
    action == "action-0077";
    resource == "resource-0077";
    "role-0077" in subject.roles;
    subject.department =~ "^department-0077.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0077 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0077 by " + subject.name
    }
