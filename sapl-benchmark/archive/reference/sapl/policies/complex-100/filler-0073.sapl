policy "filler-complex-0073"
permit
    action == "action-0073";
    resource == "resource-0073";
    "role-0073" in subject.roles;
    subject.department =~ "^department-0073.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0073 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0073 by " + subject.name
    }
