policy "filler-complex-0098"
permit
    action == "action-0098";
    resource == "resource-0098";
    "role-0098" in subject.roles;
    subject.department =~ "^department-0098.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0098 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0098 by " + subject.name
    }
