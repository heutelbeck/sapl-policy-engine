policy "filler-complex-0039"
permit
    action == "action-0039";
    resource == "resource-0039";
    "role-0039" in subject.roles;
    subject.department =~ "^department-0039.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0039 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0039 by " + subject.name
    }
