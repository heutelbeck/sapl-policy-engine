policy "filler-complex-0058"
permit
    action == "action-0058";
    resource == "resource-0058";
    "role-0058" in subject.roles;
    subject.department =~ "^department-0058.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0058 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0058 by " + subject.name
    }
