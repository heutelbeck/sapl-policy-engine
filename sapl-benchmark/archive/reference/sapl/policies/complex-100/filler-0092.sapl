policy "filler-complex-0092"
permit
    action == "action-0092";
    resource == "resource-0092";
    "role-0092" in subject.roles;
    subject.department =~ "^department-0092.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0092 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0092 by " + subject.name
    }
