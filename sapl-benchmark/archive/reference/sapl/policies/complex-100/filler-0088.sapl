policy "filler-complex-0088"
permit
    action == "action-0088";
    resource == "resource-0088";
    "role-0088" in subject.roles;
    subject.department =~ "^department-0088.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0088 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0088 by " + subject.name
    }
