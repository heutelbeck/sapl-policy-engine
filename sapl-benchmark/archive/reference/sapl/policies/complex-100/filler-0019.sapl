policy "filler-complex-0019"
permit
    action == "action-0019";
    resource == "resource-0019";
    "role-0019" in subject.roles;
    subject.department =~ "^department-0019.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0019 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0019 by " + subject.name
    }
