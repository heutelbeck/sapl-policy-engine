policy "filler-complex-0099"
permit
    action == "action-0099";
    resource == "resource-0099";
    "role-0099" in subject.roles;
    subject.department =~ "^department-0099.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0099 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0099 by " + subject.name
    }
