policy "filler-complex-0025"
permit
    action == "action-0025";
    resource == "resource-0025";
    "role-0025" in subject.roles;
    subject.department =~ "^department-0025.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0025 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0025 by " + subject.name
    }
