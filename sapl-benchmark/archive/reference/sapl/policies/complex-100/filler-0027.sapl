policy "filler-complex-0027"
permit
    action == "action-0027";
    resource == "resource-0027";
    "role-0027" in subject.roles;
    subject.department =~ "^department-0027.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0027 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0027 by " + subject.name
    }
