policy "filler-complex-0069"
permit
    action == "action-0069";
    resource == "resource-0069";
    "role-0069" in subject.roles;
    subject.department =~ "^department-0069.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0069 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0069 by " + subject.name
    }
