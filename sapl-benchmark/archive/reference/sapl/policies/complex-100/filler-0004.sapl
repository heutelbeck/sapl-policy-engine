policy "filler-complex-0004"
permit
    action == "action-0004";
    resource == "resource-0004";
    "role-0004" in subject.roles;
    subject.department =~ "^department-0004.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0004 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0004 by " + subject.name
    }
