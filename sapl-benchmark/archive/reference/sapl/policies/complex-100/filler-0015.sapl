policy "filler-complex-0015"
permit
    action == "action-0015";
    resource == "resource-0015";
    "role-0015" in subject.roles;
    subject.department =~ "^department-0015.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0015 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0015 by " + subject.name
    }
