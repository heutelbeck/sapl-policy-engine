policy "filler-complex-0062"
permit
    action == "action-0062";
    resource == "resource-0062";
    "role-0062" in subject.roles;
    subject.department =~ "^department-0062.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0062 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0062 by " + subject.name
    }
