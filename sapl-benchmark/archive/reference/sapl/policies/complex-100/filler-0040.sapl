policy "filler-complex-0040"
permit
    action == "action-0040";
    resource == "resource-0040";
    "role-0040" in subject.roles;
    subject.department =~ "^department-0040.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0040 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0040 by " + subject.name
    }
