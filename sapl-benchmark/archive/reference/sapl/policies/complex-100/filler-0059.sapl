policy "filler-complex-0059"
permit
    action == "action-0059";
    resource == "resource-0059";
    "role-0059" in subject.roles;
    subject.department =~ "^department-0059.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0059 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0059 by " + subject.name
    }
