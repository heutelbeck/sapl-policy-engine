policy "filler-complex-0032"
permit
    action == "action-0032";
    resource == "resource-0032";
    "role-0032" in subject.roles;
    subject.department =~ "^department-0032.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0032 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0032 by " + subject.name
    }
