policy "filler-complex-0081"
permit
    action == "action-0081";
    resource == "resource-0081";
    "role-0081" in subject.roles;
    subject.department =~ "^department-0081.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0081 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0081 by " + subject.name
    }
