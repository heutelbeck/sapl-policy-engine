policy "filler-complex-0045"
permit
    action == "action-0045";
    resource == "resource-0045";
    "role-0045" in subject.roles;
    subject.department =~ "^department-0045.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0045 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0045 by " + subject.name
    }
