policy "filler-complex-0071"
permit
    action == "action-0071";
    resource == "resource-0071";
    "role-0071" in subject.roles;
    subject.department =~ "^department-0071.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0071 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0071 by " + subject.name
    }
