policy "filler-complex-0014"
permit
    action == "action-0014";
    resource == "resource-0014";
    "role-0014" in subject.roles;
    subject.department =~ "^department-0014.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0014 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0014 by " + subject.name
    }
