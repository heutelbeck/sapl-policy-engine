policy "filler-complex-0026"
permit
    action == "action-0026";
    resource == "resource-0026";
    "role-0026" in subject.roles;
    subject.department =~ "^department-0026.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0026 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0026 by " + subject.name
    }
