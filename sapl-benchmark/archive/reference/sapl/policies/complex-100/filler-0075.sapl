policy "filler-complex-0075"
permit
    action == "action-0075";
    resource == "resource-0075";
    "role-0075" in subject.roles;
    subject.department =~ "^department-0075.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0075 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0075 by " + subject.name
    }
