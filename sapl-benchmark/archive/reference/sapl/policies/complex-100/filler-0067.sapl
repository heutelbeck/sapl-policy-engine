policy "filler-complex-0067"
permit
    action == "action-0067";
    resource == "resource-0067";
    "role-0067" in subject.roles;
    subject.department =~ "^department-0067.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0067 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0067 by " + subject.name
    }
