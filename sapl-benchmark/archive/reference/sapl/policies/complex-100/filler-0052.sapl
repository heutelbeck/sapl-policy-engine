policy "filler-complex-0052"
permit
    action == "action-0052";
    resource == "resource-0052";
    "role-0052" in subject.roles;
    subject.department =~ "^department-0052.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0052 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0052 by " + subject.name
    }
