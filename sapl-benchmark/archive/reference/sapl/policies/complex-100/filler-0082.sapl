policy "filler-complex-0082"
permit
    action == "action-0082";
    resource == "resource-0082";
    "role-0082" in subject.roles;
    subject.department =~ "^department-0082.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0082 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0082 by " + subject.name
    }
