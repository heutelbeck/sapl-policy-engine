policy "filler-complex-0074"
permit
    action == "action-0074";
    resource == "resource-0074";
    "role-0074" in subject.roles;
    subject.department =~ "^department-0074.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0074 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0074 by " + subject.name
    }
