policy "filler-complex-0031"
permit
    action == "action-0031";
    resource == "resource-0031";
    "role-0031" in subject.roles;
    subject.department =~ "^department-0031.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0031 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0031 by " + subject.name
    }
