policy "filler-complex-0013"
permit
    action == "action-0013";
    resource == "resource-0013";
    "role-0013" in subject.roles;
    subject.department =~ "^department-0013.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0013 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0013 by " + subject.name
    }
