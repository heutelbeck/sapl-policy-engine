policy "filler-complex-0056"
permit
    action == "action-0056";
    resource == "resource-0056";
    "role-0056" in subject.roles;
    subject.department =~ "^department-0056.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0056 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0056 by " + subject.name
    }
