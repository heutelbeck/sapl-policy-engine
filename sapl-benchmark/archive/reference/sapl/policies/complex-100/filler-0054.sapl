policy "filler-complex-0054"
permit
    action == "action-0054";
    resource == "resource-0054";
    "role-0054" in subject.roles;
    subject.department =~ "^department-0054.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0054 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0054 by " + subject.name
    }
