policy "filler-complex-0093"
permit
    action == "action-0093";
    resource == "resource-0093";
    "role-0093" in subject.roles;
    subject.department =~ "^department-0093.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0093 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0093 by " + subject.name
    }
