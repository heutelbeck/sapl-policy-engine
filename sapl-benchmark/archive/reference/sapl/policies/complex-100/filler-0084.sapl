policy "filler-complex-0084"
permit
    action == "action-0084";
    resource == "resource-0084";
    "role-0084" in subject.roles;
    subject.department =~ "^department-0084.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0084 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0084 by " + subject.name
    }
