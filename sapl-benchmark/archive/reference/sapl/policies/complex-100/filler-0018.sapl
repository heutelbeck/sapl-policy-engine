policy "filler-complex-0018"
permit
    action == "action-0018";
    resource == "resource-0018";
    "role-0018" in subject.roles;
    subject.department =~ "^department-0018.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0018 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0018 by " + subject.name
    }
