policy "filler-complex-0043"
permit
    action == "action-0043";
    resource == "resource-0043";
    "role-0043" in subject.roles;
    subject.department =~ "^department-0043.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0043 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0043 by " + subject.name
    }
