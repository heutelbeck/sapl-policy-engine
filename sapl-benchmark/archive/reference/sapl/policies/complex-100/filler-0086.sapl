policy "filler-complex-0086"
permit
    action == "action-0086";
    resource == "resource-0086";
    "role-0086" in subject.roles;
    subject.department =~ "^department-0086.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0086 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0086 by " + subject.name
    }
