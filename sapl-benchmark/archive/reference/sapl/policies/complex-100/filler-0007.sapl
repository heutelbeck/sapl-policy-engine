policy "filler-complex-0007"
permit
    action == "action-0007";
    resource == "resource-0007";
    "role-0007" in subject.roles;
    subject.department =~ "^department-0007.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0007 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0007 by " + subject.name
    }
