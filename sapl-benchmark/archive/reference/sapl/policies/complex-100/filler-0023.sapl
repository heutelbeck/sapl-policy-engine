policy "filler-complex-0023"
permit
    action == "action-0023";
    resource == "resource-0023";
    "role-0023" in subject.roles;
    subject.department =~ "^department-0023.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0023 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0023 by " + subject.name
    }
