policy "filler-complex-0029"
permit
    action == "action-0029";
    resource == "resource-0029";
    "role-0029" in subject.roles;
    subject.department =~ "^department-0029.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0029 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0029 by " + subject.name
    }
