policy "filler-complex-0022"
permit
    action == "action-0022";
    resource == "resource-0022";
    "role-0022" in subject.roles;
    subject.department =~ "^department-0022.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0022 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0022 by " + subject.name
    }
