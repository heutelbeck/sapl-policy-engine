policy "filler-complex-0083"
permit
    action == "action-0083";
    resource == "resource-0083";
    "role-0083" in subject.roles;
    subject.department =~ "^department-0083.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0083 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0083 by " + subject.name
    }
