policy "filler-complex-0076"
permit
    action == "action-0076";
    resource == "resource-0076";
    "role-0076" in subject.roles;
    subject.department =~ "^department-0076.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0076 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0076 by " + subject.name
    }
