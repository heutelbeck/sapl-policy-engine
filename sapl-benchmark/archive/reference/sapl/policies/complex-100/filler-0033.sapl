policy "filler-complex-0033"
permit
    action == "action-0033";
    resource == "resource-0033";
    "role-0033" in subject.roles;
    subject.department =~ "^department-0033.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0033 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0033 by " + subject.name
    }
