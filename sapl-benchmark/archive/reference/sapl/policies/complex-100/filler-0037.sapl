policy "filler-complex-0037"
permit
    action == "action-0037";
    resource == "resource-0037";
    "role-0037" in subject.roles;
    subject.department =~ "^department-0037.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0037 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0037 by " + subject.name
    }
