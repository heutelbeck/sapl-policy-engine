policy "filler-complex-0085"
permit
    action == "action-0085";
    resource == "resource-0085";
    "role-0085" in subject.roles;
    subject.department =~ "^department-0085.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0085 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0085 by " + subject.name
    }
