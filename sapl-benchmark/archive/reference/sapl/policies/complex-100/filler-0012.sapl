policy "filler-complex-0012"
permit
    action == "action-0012";
    resource == "resource-0012";
    "role-0012" in subject.roles;
    subject.department =~ "^department-0012.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0012 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0012 by " + subject.name
    }
