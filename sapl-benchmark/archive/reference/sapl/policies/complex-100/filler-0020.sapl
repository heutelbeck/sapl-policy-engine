policy "filler-complex-0020"
permit
    action == "action-0020";
    resource == "resource-0020";
    "role-0020" in subject.roles;
    subject.department =~ "^department-0020.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0020 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0020 by " + subject.name
    }
