policy "filler-complex-0028"
permit
    action == "action-0028";
    resource == "resource-0028";
    "role-0028" in subject.roles;
    subject.department =~ "^department-0028.*";
    var ref = subject.clearanceLevel;
obligation
    {
        "type"    : "logAccess",
        "message" : "User " + subject.name + " accessed resource-0028 at level " + ref
    }
advice
    {
        "type"    : "audit",
        "details" : "access to resource-0028 by " + subject.name
    }
